rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTenant(data) {
      return isSignedIn() && data.tenantId == request.auth.uid;
    }

    function hasText(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function hasTimestamp(value) {
      return value == null || value is timestamp;
    }

    function connectionPath(connectionId) {
      return /databases/$(database)/documents/connections/$(connectionId);
    }

    function belongsToTenantConnection(connectionId) {
      return hasText(connectionId, 120)
        && exists(connectionPath(connectionId))
        && get(connectionPath(connectionId)).data.tenantId == request.auth.uid;
    }

    match /connections/{connectionId} {
      allow read, delete: if isTenant(resource.data);
      allow create: if isTenant(request.resource.data)
        && hasText(request.resource.data.name, 120)
        && request.resource.data.keys().hasOnly(['tenantId', 'name', 'createdAt', 'updatedAt']);
      allow update: if isTenant(resource.data)
        && isTenant(request.resource.data)
        && hasText(request.resource.data.name, 120)
        && request.resource.data.keys().hasOnly(['tenantId', 'name', 'createdAt', 'updatedAt']);
    }

    match /contacts/{contactId} {
      allow read, delete: if isTenant(resource.data);
      allow create: if isTenant(request.resource.data)
        && belongsToTenantConnection(request.resource.data.connectionId)
        && hasText(request.resource.data.name, 120)
        && hasText(request.resource.data.phone, 30)
        && request.resource.data.keys().hasOnly(['tenantId', 'connectionId', 'name', 'phone', 'createdAt', 'updatedAt']);
      allow update: if isTenant(resource.data)
        && isTenant(request.resource.data)
        && belongsToTenantConnection(request.resource.data.connectionId)
        && hasText(request.resource.data.name, 120)
        && hasText(request.resource.data.phone, 30)
        && request.resource.data.keys().hasOnly(['tenantId', 'connectionId', 'name', 'phone', 'createdAt', 'updatedAt']);
    }

    match /messages/{messageId} {
      allow read, delete: if isTenant(resource.data);
      allow create: if isTenant(request.resource.data)
        && belongsToTenantConnection(request.resource.data.connectionId)
        && hasText(request.resource.data.body, 5000)
        && request.resource.data.contactIds is list
        && request.resource.data.contactIds.size() > 0
        && (request.resource.data.status in ['scheduled', 'sent'])
        && hasTimestamp(request.resource.data.scheduledAt)
        && hasTimestamp(request.resource.data.sentAt)
        && request.resource.data.keys().hasOnly([
          'tenantId',
          'connectionId',
          'body',
          'contactIds',
          'status',
          'scheduledAt',
          'sentAt',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isTenant(resource.data)
        && isTenant(request.resource.data)
        && belongsToTenantConnection(request.resource.data.connectionId)
        && hasText(request.resource.data.body, 5000)
        && request.resource.data.contactIds is list
        && request.resource.data.contactIds.size() > 0
        && (request.resource.data.status in ['scheduled', 'sent'])
        && hasTimestamp(request.resource.data.scheduledAt)
        && hasTimestamp(request.resource.data.sentAt)
        && request.resource.data.keys().hasOnly([
          'tenantId',
          'connectionId',
          'body',
          'contactIds',
          'status',
          'scheduledAt',
          'sentAt',
          'createdAt',
          'updatedAt'
        ]);
    }
  }
}
